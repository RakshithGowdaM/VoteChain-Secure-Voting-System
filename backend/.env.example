# Copy this file to .env and fill in values before starting the server

NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/votechain

# JWT
JWT_SECRET=change-me-to-a-strong-random-string
JWT_EXPIRES_IN=2h

# Phone hash salt (add to protect voter privacy)
PHONE_HASH_SECRET=change-me-too

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=votechain2025

# Twilio OTP (leave blank to use console-logged OTPs in development)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Blockchain (optional — leave blank to skip on-chain recording)
BLOCKCHAIN_RPC_URL=
PRIVATE_KEY=
CONTRACT_ADDRESS=

# CORS
FRONTEND_URL=http://localhost:3000

# Election
ELECTION_NAME=General Election 2025

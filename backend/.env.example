# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/votechain

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=2h

# Twilio OTP
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Blockchain (Ethereum)
BLOCKCHAIN_RPC_URL=https://mainnet.infura.io/v3/your_infura_project_id
# For testnet: https://sepolia.infura.io/v3/your_project_id
PRIVATE_KEY=your_wallet_private_key_never_share_this
CONTRACT_ADDRESS=0xYourDeployedContractAddress

# Voting Config
ELECTION_START=2026-01-01T00:00:00Z
ELECTION_END=2027-12-31T23:59:59Z
ELECTION_NAME=General Election 2026

# Rate Limiting
OTP_RATE_LIMIT_WINDOW_MS=900000
OTP_RATE_LIMIT_MAX=5

# CORS
FRONTEND_URL=http://localhost:3000,https://cosmic-swan-394e55.netlify.app

# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=votechain2025
